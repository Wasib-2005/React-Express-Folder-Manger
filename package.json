{
  "name": "file-manager",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "postinstall": "echo 'Installing backend...' && npm install --prefix backend && echo 'Installing frontend...' && npm install --prefix frontend",
    "dev": "concurrently \"npm run frontend\" \"npm run backend\"",
    "start": "npm run frontendBuild && concurrently \"npm run frontendRun\" \"npm run backendRun\"",
    "frontend": "npm run dev --prefix frontend -- --host",
    "backend": "npm run dev --prefix backend",
    "frontendRun": "npm run preview --prefix frontend -- --host",
    "backendRun": "npm run start --prefix backend",
    "frontendBuild": "npm run build --prefix frontend",
    "playwright": "node Playwright/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wasib-2005/React-Express-Folder-Manger.git"
  },
  "keywords": [],
